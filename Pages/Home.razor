@page "/"
<PageTitle>Neural Systems | Industrial Automation for Apple Ecosystems</PageTitle>

<section class="hero" aria-labelledby="hero-title">
    <div class="ambient-grid" aria-hidden="true"></div>
    <div class="orb orb-one" aria-hidden="true"></div>
    <div class="orb orb-two" aria-hidden="true"></div>

    <header class="topbar">
        <a class="brand" href="/" aria-label="Neural Systems home">
            <img src="assets/neural-logo.svg" alt="Neural Systems" />
        </a>
        <span class="status-pill">
            <span class="pulse" aria-hidden="true"></span>
            Launching soon
        </span>
    </header>

    <div class="hero-content">
        <div class="glass-card intro-card">
            <p class="eyebrow">Industrial automation. Native mindset.</p>
            <h1 id="hero-title">Automation intelligence for modern industrial systems.</h1>
            <p class="lead">
                We are building a refined engineering platform for industrial automation teams working in the Apple ecosystem.
            </p>

            <div class="actions" aria-label="Landing page calls to action">
                <a class="primary-action" href="mailto:contact@neuralsystems.local?subject=Neural%20Systems%20Launch%20Information">
                    Request early access
                </a>
                <span class="secondary-note">Coming soon</span>
            </div>
        </div>

        <aside class="glass-card telemetry-card" aria-label="Industrial automation preview panel">
            <div class="panel-header">
                <span>Edge Gateway</span>
                <strong>Online</strong>
            </div>

            <div class="signal-stack">
                <div class="signal-row">
                    <span>Native Driver</span>
                    <strong>8 ms</strong>
                </div>
                <div class="signal-row">
                    <span>Industrial UX/UI Interfaces</span>
                    <strong>Stable</strong>
                </div>
                <div class="signal-row">
                    <span>Tag Streams</span>
                    <strong>1,248</strong>
                </div>
            </div>

            <div class="mini-diagram" aria-hidden="true">
                <span class="node node-a"></span>
                <span class="node node-b"></span>
                <span class="node node-c"></span>
                <span class="node node-d"></span>
                <span class="trace trace-one"></span>
                <span class="trace trace-two"></span>
                <span class="trace trace-three"></span>
            </div>
        </aside>
    </div>

    <footer class="footer-note">
        <span>Designed for industrial clarity.</span>
        <span>Native drivers • Industrial UX/UI • Diagnostics • Operational visibility</span>
    </footer>
</section>
